# Base URL for the gum_api REST endpoints (no trailing slash).
# Local dev — matches `npm run dev` of gum_api which logs:
#   API base: http://localhost:5001/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:5001/api/v1

# Optional — site URL for og:url / canonical
NEXT_PUBLIC_SITE_URL=http://localhost:3001
